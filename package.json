{
  "name": "cobe-funnel-ops",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"ADMIN_USERNAME=operator ADMIN_PASSWORD=operator ADMIN_SESSION_SECRET=local-dev-session-secret-override ADMIN_SESSION_COOKIE_SECURE=false node --env-file=.env.local server/index.js\" \"vite\"",
    "dev:api": "ADMIN_USERNAME=operator ADMIN_PASSWORD=operator ADMIN_SESSION_SECRET=local-dev-session-secret-override ADMIN_SESSION_COOKIE_SECURE=false node --env-file=.env.local server/index.js",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "ADMIN_USERNAME=operator ADMIN_PASSWORD=operator ADMIN_SESSION_SECRET=local-dev-session-secret-override ADMIN_SESSION_COOKIE_SECURE=false node --env-file=.env.local server/index.js",
    "reset:data": "ADMIN_USERNAME=operator ADMIN_PASSWORD=operator ADMIN_SESSION_SECRET=local-dev-session-secret-override ADMIN_SESSION_COOKIE_SECURE=false node --env-file=.env.local -e \"import('./server/store.js').then((m)=>m.resetState())\"",
    "test:backend": "ADMIN_USERNAME=operator ADMIN_PASSWORD=operator ADMIN_SESSION_SECRET=local-dev-session-secret-override ADMIN_SESSION_COOKIE_SECURE=false node --env-file=.env.local server/smoke.mjs",
    "test:http": "ADMIN_USERNAME=operator ADMIN_PASSWORD=operator ADMIN_SESSION_SECRET=local-dev-session-secret-override ADMIN_SESSION_COOKIE_SECURE=false node --env-file=.env.local server/http-smoke.mjs"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "geist": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
